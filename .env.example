# Groq LLM
GROQ_API_KEY=gsk_your_groq_api_key_here

# Audit chain HMAC secret (min 32 chars, keep secret)
AUDIT_SECRET=change_me_audit_secret_at_least_32_chars_long

# Per-agent HMAC signing secrets (used by agents calling governance)
TRIAGE_AGENT_SECRET=change_me_triage_secret_at_least_32_chars
INVESTIGATOR_AGENT_SECRET=change_me_investigator_secret_32_chars

# Server
APP_HOST=127.0.0.1
APP_PORT=8000

# Agent version tag (embedded in every AgentDecision)
AGENT_VERSION=1.0.0
